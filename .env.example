# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=interviewprep_db
POSTGRES_USER=interviewprep
POSTGRES_PASSWORD=<generate-a-strong-password>

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=<generate-a-256-bit-random-key>
JWT_ISSUER=InterviewPrepAPI
JWT_AUDIENCE=InterviewPrepApp
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION=7

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGIN=https://your-frontend-domain.com

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=InterviewPrep
